      "value": "http://localhost:8081/playground",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "@NoPhone",
      "item": [
        {
          "name": "FAIL — numéro de téléphone détecté → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 (REJECT)', function() {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Response body contains field and detector', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('field');",
                  "  pm.expect(json.detector).to.equal('phone');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": \"06 12 34 56 78\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/no-phone",
              "host": ["{{baseUrl}}"],
              "path": ["no-phone"]
            }
          },
          "response": []
        },
        {
          "name": "PASS — texte propre → 200",
