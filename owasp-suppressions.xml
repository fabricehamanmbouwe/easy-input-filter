<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    FALSE POSITIVE — log4j-api (CVE-2026-34478 to 34481)
    These CVE affect log4j-core only (the appender/layout execution engine).
    log4j-api is a thin logging facade with no deserialization or runtime
    execution code. Our dependency on log4j-api is transitive via SLF4J;
    we never depend on log4j-core.
  -->
  <suppress>
    <notes>CVE affects log4j-core only, not log4j-api which is a thin facade</notes>
    <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-api@.*$</packageUrl>
    <cve>CVE-2026-34478</cve>
    <cve>CVE-2026-34479</cve>
    <cve>CVE-2026-34480</cve>
    <cve>CVE-2026-34481</cve>
  </suppress>

  <!--
    FALSE POSITIVE — Spring Boot CVE (provided scope)
    easy-input-filter is a library starter, not an application.
    ALL spring-boot-* dependencies are declared with scope=provided or
    scope=test in every module (aop, autoconfigure). They are NOT bundled
    into our JARs — the host application brings its own Spring Boot version.

    Therefore, CVE affecting Spring Boot components (spring-core, spring-web,
    spring-boot-autoconfigure, etc.) are the responsibility of the host
    application, not of this library. OWASP Dependency-Check flags them
    because they appear on the compilation classpath, but they are not
    shipped as transitive dependencies of our artifacts.

    Users of easy-input-filter should upgrade their own Spring Boot version
    to address any Spring Boot CVE. Our minimum tested version is 3.3.4.
  -->
  <suppress>
    <notes>Spring Boot is provided-scope — not bundled in our JARs; CVE is host app responsibility</notes>
    <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/.*@.*$</packageUrl>
    <cvssBelow>10</cvssBelow>
  </suppress>

  <suppress>
    <notes>Spring Framework is provided-scope — not bundled in our JARs; CVE is host app responsibility</notes>
    <packageUrl regex="true">^pkg:maven/org\.springframework/.*@.*$</packageUrl>
    <cvssBelow>10</cvssBelow>
  </suppress>

  <!--
    FALSE POSITIVE — spring-boot-devtools (CVE-2026-40972)
    easy-input-filter does not declare spring-boot-devtools at any scope.
    If it appears in the scan it is only because dependency-check scans
    the full classpath including test-scope transitive deps of example-app.
  -->
  <suppress>
    <notes>spring-boot-devtools is not a dependency of easy-input-filter library artifacts</notes>
    <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-devtools@.*$</packageUrl>
    <cve>CVE-2026-40972</cve>
  </suppress>

</suppressions>
